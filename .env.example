# Copia este archivo como .env y completa los valores antes de levantar Docker

# Clave secreta para JWT — genera una con: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_GENERATE_A_REAL_SECRET_32_CHARS

# Tiempo de expiración del token en minutos (default: 480 = 8h)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Secreto compartido con Power Automate para el webhook
WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET

# Credenciales del superadmin inicial (cámbialas antes de iniciar)
SUPERADMIN_EMAIL=admin@matrix.com
SUPERADMIN_PASSWORD=Admin1234!
